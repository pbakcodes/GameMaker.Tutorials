draw_set_color(c_yellow);
draw_set_halign(fa_center);
draw_set_valign(fa_middle);
draw_text(display_get_gui_width() / 2, display_get_gui_height() / 2 - 20, "YOU WIN!");
draw_set_color(c_white);
draw_text(display_get_gui_width() / 2, display_get_gui_height() / 2 + 20, "Press ENTER to play again");
draw_set_halign(fa_left);
draw_set_valign(fa_top);
